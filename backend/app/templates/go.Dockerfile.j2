# Stage 1: Build
FROM {{ base_image | default("golang:1.22-alpine", true) }} AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /app/bin/app .

# Stage 2: Runtime (scratch = minimal image)
FROM alpine:latest

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

COPY --from=builder /app/bin/app /app/app

USER appuser

{% if port %}
EXPOSE {{ port }}
{% endif %}

{% for env in env_vars %}
ENV {{ env.key }}={{ env.value }}
{% endfor %}

CMD {{ startup_command | default("./app", true) | tojson }}
