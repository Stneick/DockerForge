FROM {{ base_image | default("node:20-slim", true) }} AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build


FROM {{ base_image | default("node:20-slim", true) }} AS production

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/dist ./dist

RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser && \
    chown -R appuser:appgroup /app
USER appuser

{% for env in env_vars %}
ENV {{ env.key }}={{ env.value }}
{% endfor %}

ENV NODE_ENV=production

EXPOSE {{ port | default(3000, true) }}

CMD ["node", "{{ entry_point | default('dist/src/main', true) }}"]
