FROM {{ base_image | default("node:20-slim", true) }}

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY . .

RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser && \
    chown -R appuser:appgroup /app
USER appuser

{% for env in env_vars %}
ENV {{ env.key }}={{ env.value }}
{% endfor %}

ENV NODE_ENV=production

EXPOSE {{ port | default(3000, true) }}

CMD {{ startup_command | default("node index.js", true) | tojson }}
