# Stage 1: Build
FROM {{ base_image | default("gcc:latest", true) }} AS builder

WORKDIR /app

COPY . .

{% if dependency_file == "CMakeLists.txt" %}
RUN apt-get update && apt-get install -y cmake && \
    mkdir build && cd build && cmake .. && make
{% elif dependency_file == "Makefile" %}
RUN make
{% else %}
RUN gcc -o app *.c
{% endif %}

# Stage 2: Runtime
FROM debian:bookworm-slim

RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser

WORKDIR /app

{% if dependency_file == "CMakeLists.txt" %}
COPY --from=builder /app/build/app .
{% elif dependency_file == "Makefile" %}
COPY --from=builder /app/app .
{% else %}
COPY --from=builder /app/app .
{% endif %}

USER appuser

{% if port %}
EXPOSE {{ port }}
{% endif %}

{% for env in env_vars %}
ENV {{ env.key }}={{ env.value }}
{% endfor %}

CMD {{ startup_command | default("./app", true) | tojson }}
