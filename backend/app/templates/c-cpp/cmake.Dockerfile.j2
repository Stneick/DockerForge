FROM {{ base_image | default("gcc:13-bookworm", true) }} AS builder

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends cmake && \
    rm -rf /var/lib/apt/lists/*

COPY . .

RUN mkdir -p build && \
    cd build && \
    cmake -DCMAKE_BUILD_TYPE=Release .. && \
    make -j$(nproc)


FROM debian:bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/* && \
    addgroup --system appgroup && \
    adduser --system --ingroup appgroup appuser

WORKDIR /app

COPY --from=builder /app/build/{{ binary_name | default("app", true) }} .

USER appuser

{% for env in env_vars %}
ENV {{ env.key }}={{ env.value }}
{% endfor %}

{% if port %}
EXPOSE {{ port }}
{% endif %}

CMD ["./{{ binary_name | default('app', true) }}"]
