FROM {{ base_image | default("python:3.12-slim", true) }}

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc && \
    rm -rf /var/lib/apt/lists/*

COPY {{ dependency_file | default("requirements.txt", true) }} .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r {{ dependency_file | default("requirements.txt", true) }}

COPY . .

RUN addgroup --system appgroup && \
    adduser --system --ingroup appgroup appuser && \
    chown -R appuser:appgroup /app
USER appuser

{% for env in env_vars %}
ENV {{ env.key }}={{ env.value }}
{% endfor %}

EXPOSE {{ port | default(8000, true) }}

CMD ["uvicorn", "{{ entry_point | default('main:app', true) }}", "--host", "0.0.0.0", "--port", "{{ port | default(8000, true) }}"]
