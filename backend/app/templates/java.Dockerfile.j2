# Stage 1: Build with Maven or Gradle
FROM {{ base_image | default("eclipse-temurin:21-jdk-alpine", true) }} AS builder

WORKDIR /app

COPY . .

{% if dependency_file == "pom.xml" %}
RUN apk add --no-cache maven && mvn clean package -DskipTests
{% elif dependency_file in ["build.gradle", "build.gradle.kts"] %}
RUN chmod +x gradlew && ./gradlew build -x test
{% endif %}

# Stage 2: Runtime (JRE only)
FROM eclipse-temurin:21-jre-alpine

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

WORKDIR /app

{% if dependency_file == "pom.xml" %}
COPY --from=builder /app/target/*.jar app.jar
{% elif dependency_file in ["build.gradle", "build.gradle.kts"] %}
COPY --from=builder /app/build/libs/*.jar app.jar
{% endif %}

USER appuser

{% if port %}
EXPOSE {{ port }}
{% endif %}

{% for env in env_vars %}
ENV {{ env.key }}={{ env.value }}
{% endfor %}

CMD {{ startup_command | default("java -jar app.jar", true) | tojson }}
