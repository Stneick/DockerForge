# Database
DB_USER=dockerforge
DB_PASSWORD=dockerforge
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dockerforge

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Docker Build
BUILD_TIMEOUT_SECONDS=600
BUILD_MAX_CONCURRENT=2
BUILD_MEMORY_LIMIT=512m
BUILD_CPU_LIMIT=1.0
IMAGE_TTL_SECONDS=3600

# Upload
MAX_UPLOAD_SIZE_MB=100
UPLOAD_TEMP_DIR=/tmp/dockerforge/uploads

# CORS
CORS_ORIGINS=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=dev
